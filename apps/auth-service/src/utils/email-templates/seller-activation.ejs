<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eshop – Activate Your Seller Account</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap');

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'DM Sans', Arial, sans-serif;
            background-color: #F5F0E8;
            color: #1A1410;
            -webkit-font-smoothing: antialiased;
        }

        .wrapper {
            width: 100%;
            background-color: #F5F0E8;
            padding: 48px 16px;
        }

        .card {
            max-width: 560px;
            margin: 0 auto;
            background-color: #FFFDF9;
            border-radius: 4px;
            overflow: hidden;
            border: 1px solid #E8E0D0;
            box-shadow: 0 4px 32px rgba(26, 20, 16, 0.08);
        }

        /* Header */
        .header {
            background-color: #1A1410;
            padding: 36px 48px 32px;
            position: relative;
            overflow: hidden;
        }

        .header::before {
            content: '';
            position: absolute;
            top: -60px;
            right: -60px;
            width: 200px;
            height: 200px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(212, 167, 106, 0.18) 0%, transparent 70%);
        }

        .header::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(212, 167, 106, 0.5), transparent);
        }

        .logo {
            font-family: 'DM Serif Display', Georgia, serif;
            font-size: 28px;
            letter-spacing: 0.12em;
            color: #F5F0E8;
            text-transform: uppercase;
            position: relative;
        }

        .logo span {
            color: #D4A76A;
        }

        .tagline {
            font-size: 11px;
            font-weight: 300;
            letter-spacing: 0.22em;
            color: rgba(245, 240, 232, 0.45);
            text-transform: uppercase;
            margin-top: 4px;
        }

        /* Body */
        .body {
            padding: 48px 48px 40px;
        }

        .greeting {
            font-family: 'DM Serif Display', Georgia, serif;
            font-size: 26px;
            color: #1A1410;
            line-height: 1.2;
            margin-bottom: 16px;
        }

        .greeting em {
            font-style: italic;
            color: #8B6340;
        }

        .intro {
            font-size: 15px;
            font-weight: 300;
            color: #5A4A3A;
            line-height: 1.7;
            margin-bottom: 36px;
        }

        /* OTP Block */
        .otp-section {
            background-color: #F5F0E8;
            border: 1px solid #E8E0D0;
            border-radius: 4px;
            padding: 28px 32px;
            margin-bottom: 36px;
            text-align: center;
            position: relative;
        }

        .otp-label {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.24em;
            color: #8B6340;
            text-transform: uppercase;
            margin-bottom: 14px;
        }

        .otp-code {
            font-family: 'DM Serif Display', Georgia, serif;
            font-size: 52px;
            letter-spacing: 0.18em;
            color: #1A1410;
            line-height: 1;
            margin-bottom: 16px;
        }

        .otp-divider {
            width: 40px;
            height: 1px;
            background: #D4A76A;
            margin: 0 auto 14px;
        }

        .otp-expiry {
            font-size: 12px;
            font-weight: 400;
            letter-spacing: 0.06em;
            color: #8B7060;
        }

        .otp-expiry strong {
            color: #C0622B;
            font-weight: 600;
        }

        /* Note */
        .note {
            font-size: 13px;
            font-weight: 300;
            color: #7A6A5A;
            line-height: 1.7;
            border-left: 2px solid #D4A76A;
            padding-left: 16px;
            margin-bottom: 40px;
        }

        /* Footer */
        .footer-divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, #E8E0D0, transparent);
            margin: 0 48px;
        }

        .footer {
            padding: 28px 48px 32px;
        }

        .sign-off {
            font-size: 14px;
            font-weight: 300;
            color: #7A6A5A;
            margin-bottom: 4px;
        }

        .sign-name {
            font-family: 'DM Serif Display', Georgia, serif;
            font-size: 16px;
            color: #1A1410;
            letter-spacing: 0.06em;
        }

        /* Bottom bar */
        .bottom-bar {
            background-color: #1A1410;
            padding: 16px 48px;
            text-align: center;
        }

        .bottom-bar p {
            font-size: 11px;
            font-weight: 300;
            letter-spacing: 0.1em;
            color: rgba(245, 240, 232, 0.35);
        }

        /* Responsive */
        @media (max-width: 600px) {

            .header,
            .body,
            .footer,
            .bottom-bar {
                padding-left: 28px;
                padding-right: 28px;
            }

            .footer-divider {
                margin: 0 28px;
            }

            .otp-code {
                font-size: 40px;
                letter-spacing: 0.14em;
            }
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <div class="card">

            <!-- Header -->
            <div class="header">
                <div class="logo">E<span>·</span>shop</div>
                <div class="tagline">Curated Commerce</div>
            </div>

            <!-- Body -->
            <div class="body">
                <div class="greeting">Welcome,&nbsp;<em>
                        <%= name %>
                    </em></div>
                <p class="intro">
                    Thank you for joining Eshop as a seller. To complete your registration and activate your seller
                    account,
                    please use the one-time passcode below.
                </p>

                <!-- OTP -->
                <div class="otp-section">
                    <div class="otp-label">Your Verification Code</div>
                    <div class="otp-code">
                        <%= otp %>
                    </div>
                    <div class="otp-divider"></div>
                    <div class="otp-expiry">Expires in <strong>5 minutes</strong></div>
                </div>

                <p class="note">
                    If you did not create an account with Eshop, you can safely ignore this email.
                    Do not share this code with anyone.
                </p>
            </div>

            <div class="footer-divider"></div>

            <!-- Footer -->
            <div class="footer">
                <p class="sign-off">With warmth,</p>
                <p class="sign-name">The Eshop Team</p>
            </div>

            <!-- Bottom bar -->
            <div class="bottom-bar">
                <p>&copy; 2026 Eshop &nbsp;·&nbsp; All rights reserved &nbsp;·&nbsp; You're receiving this because you
                    registered with us</p>
            </div>

        </div>
    </div>
</body>

</html>